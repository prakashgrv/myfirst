generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  image        String?
  googleTokens Json?
  children     Child[]
  createdAt    DateTime  @default(now())
  accounts     Account[]
  sessions     Session[]
}

model Child {
  id            String         @id @default(cuid())
  name          String
  grade         String
  school        String?
  color         String         @default("#FF5A5F")
  avatarUrl     String?
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduleItems ScheduleItem[]
  createdAt     DateTime       @default(now())
}

model ScheduleItem {
  id             String     @id @default(cuid())
  type           ItemType
  title          String
  subject        String?
  location       String?
  dueDate        DateTime?
  startTime      DateTime?
  endTime        DateTime?
  recurring      Boolean    @default(false)
  recurrenceDays String[]
  priority       Priority   @default(MEDIUM)
  notes          String?
  completed      Boolean    @default(false)
  googleEventId  String?
  childId        String
  child          Child      @relation(fields: [childId], references: [id], onDelete: Cascade)
  reminders      Reminder[]
  createdAt      DateTime   @default(now())
}

enum ItemType {
  HOMEWORK
  ACTIVITY
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

model Reminder {
  id             String       @id @default(cuid())
  scheduleItemId String
  scheduleItem   ScheduleItem @relation(fields: [scheduleItemId], references: [id], onDelete: Cascade)
  minutesBefore  Int
  sent           Boolean      @default(false)
  sentAt         DateTime?
  createdAt      DateTime     @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
